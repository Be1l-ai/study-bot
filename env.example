# Copy this to .env for local testing (never commit .env to git)
# Set these as environment variables in Railway dashboard for deployment

BOT_TOKEN=your_telegram_bot_token_here
GROQ_KEY=your_groq_api_key_here

# Optional allowlist (comma-separated). If unset, all chats are allowed.
ALLOWED_CHAT_IDS=123456789,987654321

# Backward-compatible single-user lock.
CHAT_ID=your_telegram_chat_id_here

# Optional — defaults shown
TOPIC_INTERVAL=600    # seconds between topics (600 = 10 minutes)
QUIZ_DELAY=1800       # seconds before quiz triggers (1800 = 30 minutes)
DB_PATH=study_bot.db  # Fly.io sets this to /data/study_bot.db
